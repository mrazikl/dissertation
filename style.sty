% Custom environment for indented theorems
% Usage: \begin{indentedtheorem}[Source/Author]{Title} ... \end{indentedtheorem}
\newenvironment{theorem}
{
  \par\medskip
  \addtolength{\leftskip}{1cm}
  \addtolength{\rightskip}{1cm}
  \itshape
  \noindent\ignorespaces
}
{
  \par\medskip
  \addtolength{\leftskip}{-1cm}
  \addtolength{\rightskip}{-1cm}
}

